
process {
    // Resource ceilings. Nextflow caps each task's requested cpus/memory/time to
    // these values. This replaces the old nf-core check_max() helper (removed for
    // Nextflow 26 compatibility). Profiles in nextflow.config override this
    // per-execution-environment via `process.resourceLimits`.
    resourceLimits = [ cpus: 16, memory: '128.GB', time: '240.h' ]

    cpus   = { 1    * task.attempt }
    memory = { 4.GB * task.attempt }
    time   = { 1.h  * task.attempt }

    errorStrategy = { task.exitStatus in [143,137,104,134,139,5,6,null] ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // Process-specific resource requirements. Reuse these labels where possible;
    // they mirror the nf-core/modules conventions so the same names work there too.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors
    withLabel:process_low_constant {
        cpus   = 2
        memory = 8.GB
        time   = 1.h
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 8.GB  * task.attempt }
        time   = { 2.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 4     * task.attempt }
        memory = { 15.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 32    * task.attempt }
        memory = { 60.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 40.GB * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    // labels added for TEI-REX workflows
    withLabel:process_high_constant {
        cpus   = 128
        memory = 60.GB
        time   = 8.h
    }
}
